#!/usr/bin/env python3
"""CLI مناد — بسته‌بندیِ همان قابلیت‌های موجود؛ هیچ توانِ تازه‌ای نمی‌افزاید.

  monad status            وضعِ زندگی: ریشه‌های دیده، صفِ باز، پیوندهای دوسویه
  monad breathe [ROOT]    یک نفس: بی‌آرگومان = قاعدهٔ صف (نادرتر مقدم)؛
                          با ROOT = مواجههٔ رفیق‌آورده (نشان‌دار). خروجی: JSON.
  monad breathe-record [ROOT] [chosen_by]
                          پیش‌نمایشِ رکوردِ نفسِ بعدی (L3) از حالتِ زندهٔ
                          life.db — برای دیدنِ اینکه نفسِ بعدی چه خواهد بود،
                          پیش از ثبت. بی‌ثبت (چاپِ JSON). قابلِ اتکا برایِ
                          verifyِ دائمی نیست (breath_no با رشدِ life.db عوض
                          می‌شود) — برایِ آن از breathe-record-from استفاده کن.
  monad breathe-record-from PATH
                          بازتولیدِ قطعیِ یک رکوردِ ثبت‌شده از رویِ خودِ فایل —
                          مستقل از حالتِ زندهٔ life.db، برای همیشه پایدار.
                          اسکریپتِ درستِ ثبت‌شده در breaths.script برایِ
                          نفس‌های L3 (نه breathe-record ساده).
  monad verify            بازتولیدپذیری: اجرای دوبارهٔ اسکریپت‌های تاریخی و
                          مقایسهٔ checksum با رکوردهای متعارف
  monad seed-db           بازساختِ قطعیِ database/life.db از رکوردها
  monad observe [ROOT]    مشورت با رصدخانه (موجودِ سوم): بی‌آرگومان = کجاها
                          غیرعادی و نزیسته‌اند؛ با ROOT = سه‌نوع‌پیام. فقط نشانی،
                          هرگز نمی‌نویسد. (بساز: python3 observatory/build.py)
  monad recall ROOT       L4 — حافظهٔ انتخابی: فقط برشِ مرتبط با این ریشه از
                          life.db/graph/knowledge/رصدخانه؛ نه کلِ تاریخ.
                          فقط‌خواندنی، الگوریتمی، coverage صریح.
  monad ponder ROOT       تدبّرخانه (موجودِ چهارم — tadabbor/TADABBOR.md):
                          سیمای ساختاریِ کاملِ ریشه برای تدبّرِ باغبان —
                          آیه‌ها، صورت‌ها، صرف، پراکندگی، هم‌آیی، بافتِ مجاور.
                          فقط می‌خواند؛ فقط به tadabbor/portraits/ می‌نویسد.
  monad ponder-sync       هم‌گام با زندگی (تصمیمِ باغبان ۲۰۲۶-۰۷-۲۱): سیمای
                          هر ریشهٔ زیسته‌ای که هنوز ندارد. ایدم‌پوتنت.
  monad queue-add ROOT [یادداشت]
                          تزریقِ دستیِ یک پیشنهاد به صف (سیاستِ باغبان،
                          دیدارِ ۲۰۲۶-۰۷-۲۰): صف طبیعی مسیرِ اصلی می‌ماند؛
                          این فقط عضویت می‌دهد. منشأ خودکار: رصدخانه/مستقیم.
                          می‌نویسد به database/queue_injections.json فقط.
  monad queue-sync-observatory
                          تزریقِ خودکارِ کلِ نامزدهای «قوی»ِ نادیدهٔ رصدخانه
                          به صف — منشأ «رصدخانه (خودکار)». ایدم‌پوتنسی؛
                          هرگز pursue نمی‌کند، فقط عضویت می‌دهد.
  monad injection-report [تاریخ]
                          گزارشِ روزانهٔ تزریق‌ها (پیش‌فرض: امروز) — بر حسبِ
                          منشأ + جزئیات؛ در database/queue_injection_reports/
                          هم ذخیره می‌شود.
"""
import json
import os
import shlex
import sqlite3
import subprocess
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
os.chdir(ROOT)
sys.path.insert(0, ROOT)


QUEUE_INJECTIONS_FILE = "database/queue_injections.json"


def load_injections():
    if not os.path.exists(QUEUE_INJECTIONS_FILE):
        return []
    return json.load(open(QUEUE_INJECTIONS_FILE, encoding="utf-8"))


def save_injections(items):
    with open(QUEUE_INJECTIONS_FILE, "w", encoding="utf-8") as f:
        json.dump(items, f, ensure_ascii=False, indent=1)
        f.write("\n")


def open_queue(db):
    """صفِ باز: صفِ طبیعی (queue_events) + پیشنهادهای تزریق‌شدهٔ باغبان
    (database/queue_injections.json — سیاستِ صف، دیدارِ ۲۰۲۶-۰۷-۲۰: «صف
    طبیعی مسیرِ اصلی است؛ باغبان پیشنهاد را وارد صف می‌کند؛ گزینشِ نهایی
    همچنان با قاعدهٔ صف»). تزریق فقط عضویت می‌دهد؛ گزینش را دور نمی‌زند."""
    q = [r for (r,) in db.execute("SELECT root FROM queue_events WHERE event='queued'")]
    p = {r for (r,) in db.execute("SELECT root FROM queue_events WHERE event='pursued'")}
    seen, out = set(), []
    for r in q:
        if r not in p and r not in seen:
            seen.add(r)
            out.append(r)
    for inj in load_injections():
        r = inj["root"]
        if r not in p and r not in seen:
            seen.add(r)
            out.append(r)
    return out


def cmd_status():
    db = sqlite3.connect("database/life.db")
    breaths = db.execute("SELECT breath_no, chapter, pursued_root, chosen_by FROM breaths ORDER BY breath_no").fetchall()
    strong = db.execute("SELECT COUNT(*) FROM findings WHERE tier='قوی'").fetchone()[0]
    graph = json.load(open("graph/graph.json"))
    mutual = [f"{e['a']}↔{e['b']}" for e in graph["edges"] if e.get("mutual_strong")]
    print(json.dumps(dict(
        breaths=len(breaths),
        visited=[b[2] for b in breaths],
        chapters={b[0]: b[1] for b in breaths},
        strong_findings=strong,
        mutual_strong_pairs=mutual,
        open_queue=open_queue(db),
        queue_injections=[i for i in load_injections()
                          if i["root"] not in {b[2] for b in breaths}],
    ), ensure_ascii=False, indent=1))


def cmd_breathe(root=None):
    from engine import breath_cycle as bc
    corpus = bc.load_corpus()
    db = sqlite3.connect("database/life.db")
    queue = open_queue(db)
    if root is None:
        ordered = bc.select_rarest(queue, corpus["attest"])
        if not ordered:
            print(json.dumps({"event": "توقف: صفِ شکاف‌ها تهی است"}, ensure_ascii=False))
            return
        pursued, chosen_by = ordered[0], "قاعدهٔ صف (نادرتر مقدم)"
    else:
        pursued, chosen_by = root, "رفیق (مواجههٔ رفیق‌آورده — نشان‌دار)"
    result = bc.breathe(corpus, pursued)
    result.update(chosen_by=chosen_by,
                  queue_before=bc.select_rarest(queue, corpus["attest"]))
    print(json.dumps(result, ensure_ascii=False, indent=1))


def cmd_breathe_record(root=None, chosen_by=None):
    """رکوردِ کاملِ یک نفسِ پل (L3) — الگوریتمیِ محض، صفر توکن/مدل.

    جایگزینِ اسکریپت‌نویسیِ دستیِ bridges_breath_NN.py: پارامترها از حالتِ
    زنده مشتق می‌شوند (breath_no، lived از life.db؛ deliberation از صفِ باز).
    مثلِ `breathe` عمداً چیزی ثبت نمی‌کند — چاپِ JSON؛ رسمی‌سازی با باغبان/دهان.
    خروجی هم‌ارزِ بایت‌به‌بایتِ روشِ تاریخی است (tests/test_breathe_record.py).

    `chosen_by` وقتی ROOT صریح داده شود قابلِ بازنویسی است — برایِ
    بازتولیدپذیریِ verify: بدونِ آن، نفسِ ثبت‌شده با «رفیق» برچسب می‌خورد حتی
    اگر واقعاً با قاعدهٔ صف انتخاب شده باشد؛ اسکریپتِ verify باید عیناً همان
    منشأِ تاریخی را بازتولید کند، نه گزینشِ زنده‌ای که با گذرِ زمان تغییر
    می‌کند (queue تغییر می‌کند، پس ROOT صریح برای بازتولیدپذیری لازم است، اما
    منشأِ واقعی باید هم صریح داده شود، وگرنه گم می‌شود).
    """
    from engine import breath_cycle as bc
    corpus = bc.load_corpus()
    attest = corpus["attest"]
    db = sqlite3.connect("database/life.db")
    lived = [r for (r,) in db.execute(
        "SELECT pursued_root FROM breaths ORDER BY breath_no")]
    breath_no = (db.execute("SELECT MAX(breath_no) FROM breaths").fetchone()[0] or 0) + 1
    queue = bc.select_rarest(open_queue(db), attest)

    if root is None:
        if not queue:
            print(json.dumps({"event": "توقف: صفِ شکاف‌ها تهی است"}, ensure_ascii=False))
            return
        pursued = queue[0]
        chosen_by = chosen_by or "قاعدهٔ صف (نادرتر مقدم)"
        deliberation_queue = queue[:10]
    else:
        pursued = root
        chosen_by = chosen_by or "رفیق (مواجههٔ رفیق‌آورده — نشان‌دار)"
        deliberation_queue = ([pursued] + [r for r in queue if r != pursued])[:10]

    record = bc.breathe_record(corpus, pursued=pursued, queue=deliberation_queue,
                               lived=lived, breath_no=breath_no, chosen_by=chosen_by)
    print(json.dumps(record, ensure_ascii=False, indent=1))


def cmd_breathe_record_from(path):
    """بازتولیدِ یک رکوردِ L3 از رویِ خودِ فایلِ منجمدشده — نه از حالتِ زندهٔ
    life.db. این، نه `breathe-record ROOT`، اسکریپتِ درستِ verify برایِ
    نفس‌های L3 است: breathe-record با ROOT صریح هم بازتولیدپذیر می‌نمود، اما
    breath_no/lived/queueاش را از life.db زنده می‌خواند که با هر نفسِ تازه
    عوض می‌شود (کشفِ نفسِ ۴۲: MAX(breath_no)+1 برای همیشه رشد می‌کند). این‌جا
    همان‌طور که tests/test_breathe_record.py برایِ رکوردهای تاریخی می‌کند،
    پارامترها را از خودِ رکورد (deliberation/projection_on_map/breath_number/
    chosen_by) بازمی‌سازد — قطعی و مستقل از رشدِ آیندهٔ life.db، برایِ همیشه.
    """
    from engine import breath_cycle as bc
    corpus = bc.load_corpus()
    rec = json.load(open(path, encoding="utf-8"))
    queue = [d["root"] for d in rec["deliberation"]]
    lived = [p["pair"].split("↔")[1] for p in rec["projection_on_map"]]
    record = bc.breathe_record(corpus, pursued=rec["pursued"], queue=queue, lived=lived,
                               breath_no=rec["breath_number"], chosen_by=rec["chosen_by"])
    print(json.dumps(record, ensure_ascii=False, indent=1))


def cmd_recall(root):
    """L4 — حافظهٔ انتخابی (Retrieval): فقط برشِ مرتبط با یک ریشه، نه کلِ تاریخ.

    الگوریتمیِ محض، فقط‌خواندنی. جایگزینِ بارگذاریِ کاملِ knowledge.json/دفترها
    در هر جلسه — بدونِ حذفِ هیچ سطرِ مرتبط (زیرمجموعه‌سازیِ کامل، نه نمونه).
    `coverage` صریح می‌گوید چه کسری از کل بار شد؛ سقفِ خاموش ممنوع
    (docs/PERFORMANCE-ARCHITECTURE.md، اصلِ L4).
    """
    db = sqlite3.connect("database/life.db")
    findings_total = db.execute("SELECT COUNT(*) FROM findings").fetchone()[0]
    findings = [
        dict(breath_no=b, center=c, neighbor=n, shared=s, expected=e,
             lift=l, p_perm=p, stable=bool(st), tier=t)
        for b, c, n, s, e, l, p, st, t in db.execute(
            "SELECT breath_no, center_root, neighbor_root, shared_ayat, expected, "
            "lift, p_perm, stable, tier FROM findings "
            "WHERE center_root=? OR neighbor_root=? ORDER BY breath_no", (root, root))]

    graph = json.load(open("graph/graph.json"))
    graph_edges = [e for e in graph["edges"] if root in (e["a"], e["b"])]

    know = json.load(open("discoveries/knowledge.json"))
    strong = [f for f in know["strong_findings"] if root in (f["center"], f["neighbor"])]
    absence = [p for p in know["absence_evidence"] if root in p["pair"].split("↔")]
    spines = [s for s in know["provenance_spines"] if root in s["roots"].split("+")]

    obs_entry = None
    if os.path.exists("observatory/observatory.json"):
        obs = json.load(open("observatory/observatory.json"))
        e = next((x for x in obs["roots"] if x["root"] == root), None)
        if e:
            island = next((isl for isl in obs["edges"]["islands"] if root in isl["roots"]), None)
            obs_entry = dict(
                attestation=e["attestation"], ayat=e["ayat"], top=e["top"],
                mutual_strong_edges=[x for x in obs["edges"]["mutual_strong"]
                                     if root in (x["a"], x["b"])],
                island_size=(island["size"] if island else None))

    print(json.dumps(dict(
        root=root,
        coverage=dict(
            life_db_findings_total=findings_total,
            life_db_findings_for_root=len(findings),
            knowledge_strong_total=len(know["strong_findings"]),
            knowledge_strong_for_root=len(strong),
            knowledge_absence_total=len(know["absence_evidence"]),
            knowledge_absence_for_root=len(absence),
            knowledge_spines_total=len(know["provenance_spines"]),
            knowledge_spines_for_root=len(spines),
            note="فقط سطرهای مرتبط با این ریشه بار شد؛ کلِ تاریخ لازم نیست.",
        ),
        findings=findings,
        graph_edges=graph_edges,
        knowledge=dict(strong_findings=strong, absence_evidence=absence,
                       provenance_spines=spines),
        observatory=obs_entry,
    ), ensure_ascii=False, indent=1))


def verify_checks(db):
    """جفت‌های (اسکریپت، رکورد) برای verify — مشتقِ محضِ life.db، نه فهرستِ دستی.

    life.db از پیش این نگاشت را per-breath نگه می‌دارد (ستون‌های script/
    record_file، خودِ seed_life.py از رکوردها می‌سازد). فهرستِ دستیِ پیشین
    عیناً همین داده را تکرار می‌کرد — یک منبعِ خطای هم‌گام‌سازی که با هر نفسِ
    تازه باید دستی ویرایش می‌شد. اکنون یک منبعِ حقیقتِ واحد: افزودنِ نفسِ نو
    به life.db کافی‌ست؛ verify نیاز به ویرایش ندارد."""
    rows = db.execute(
        "SELECT script, record_file FROM breaths ORDER BY breath_no").fetchall()
    seen, out = set(), []
    for script, record in rows:
        if (script, record) not in seen:
            seen.add((script, record))
            out.append((script, record))
    return out


def _current_breath_no(db):
    return db.execute("SELECT MAX(breath_no) FROM breaths").fetchone()[0] or 0


def _today():
    import datetime
    return datetime.date.today().isoformat()


def _append_injection(root, source, note, breath_no, date):
    """هستهٔ مشترکِ ثبتِ یک تزریق — فقط به queue_injections.json می‌نویسد.
    فراخوان (queue-add یا queue-sync-observatory) مسئولِ تعیینِ منشأ است؛
    این تابع فقط append-only می‌کند و هرگز pursue/breathe صدا نمی‌زند —
    «هیچ ریشه‌ای حق ندارد خارج از قواعدِ انتخاب اجرا شود» (دستورِ باغبان):
    تزریق فقط عضویت می‌دهد، گزینشِ نهایی همچنان با open_queue+select_rarest
    در زمانِ breathe/breathe-record است، نه این‌جا."""
    items = load_injections()
    items.append(dict(root=root, source=source, note=note,
                      added_after_breath=breath_no, date=date))
    save_injections(items)
    return items


def cmd_queue_add(root, note=None):
    """تزریقِ دستیِ یک پیشنهاد به صف — سیاستِ باغبان (دیدارِ ۲۰۲۶-۰۷-۲۰):
    «صف طبیعی مسیرِ اصلی است. رصدخانه فقط پیشنهاد می‌دهد. باغبان در صورتِ
    لزوم یک پیشنهاد را وارد صف می‌کند. منشأ هر انتخاب هم ثبت می‌شود.»

    فقط به database/queue_injections.json می‌نویسد — هرگز به life.db یا
    seed_life.py (رسمی‌سازی کارِ جداگانه‌ای‌ست، LIFECYCLES.md§نفس). منشأ
    خودکار: اگر ریشه در اطلسِ رصدخانه ساختار دارد → «باغبان (رصدخانه)»؛
    وگرنه → «باغبان (مستقیم)».
    """
    db = sqlite3.connect("database/life.db")
    lived = {r for (r,) in db.execute("SELECT pursued_root FROM breaths")}
    if root in lived:
        print(json.dumps({"خطا": f"ریشهٔ «{root}» پیش‌تر زیسته شده — تزریق بی‌معناست"},
                         ensure_ascii=False))
        sys.exit(1)

    items = load_injections()
    if any(i["root"] == root for i in items):
        print(json.dumps({"پیام": f"«{root}» از پیش در صفِ تزریقی است — کاری نشد"},
                         ensure_ascii=False, indent=1))
        return

    source = "باغبان (مستقیم)"
    if os.path.exists("observatory/observatory.json"):
        obs = json.load(open("observatory/observatory.json"))
        e = next((x for x in obs["roots"] if x["root"] == root), None)
        if e and e["top"]:
            source = "باغبان (رصدخانه)"

    breath_no = _current_breath_no(db)
    _append_injection(root, source, note, breath_no, _today())
    print(json.dumps({"تزریق‌شد": root, "منشأ": source, "یادداشت": note,
                      "پس_از_نفس": breath_no}, ensure_ascii=False, indent=1))


def cmd_queue_sync_observatory():
    """تزریقِ خودکارِ پیشنهادهای رصدخانه به صف — دستورِ باغبان (۲۰۲۶-۰۷-۲۰):
    «رصدخانه مجاز است پیشنهادهای خودش را نیز وارد صف کند، اما منشأ هر تزریق
    باید ثبت شود، و هیچ ریشه‌ای حق ندارد خارج از قواعدِ انتخاب اجرا شود.»

    فقط برای نامزدهای نادیده‌ای که رصدخانه «قوی» می‌بیند (همان فهرستِ
    observe بی‌آرگومان) — هرگز معنا نمی‌سازد، فقط ساختارِ ازپیش‌محاسبه‌شده را
    عضویت می‌دهد. منشأ همیشه «رصدخانه (خودکار)» — تمایزِ صریح از تزریقِ
    دستیِ باغبان. ایدم‌پوتنسی: ریشه‌های ازپیش‌تزریق‌شده یا زیسته رد می‌شوند.
    هرگز breathe/pursue صدا نمی‌زند — فقط صف را عضویت می‌دهد."""
    if not os.path.exists("observatory/observatory.json"):
        print(json.dumps({"خطا": "رصدخانه هنوز ساخته نشده"}, ensure_ascii=False))
        sys.exit(1)
    obs = json.load(open("observatory/observatory.json"))
    db = sqlite3.connect("database/life.db")
    lived = {r for (r,) in db.execute("SELECT pursued_root FROM breaths")}
    already = {i["root"] for i in load_injections()}

    def strong_of(e):
        return [t for t in e["top"] if t["tier"] == "قوی"]

    candidates = [e for e in obs["roots"]
                 if e["root"] not in lived and e["root"] not in already and strong_of(e)]
    peak = lambda e: max((t["lift"] for t in strong_of(e)), default=0)
    candidates.sort(key=lambda e: (-peak(e), e["root"]))  # قطعی: lift سپس الفبا

    breath_no = _current_breath_no(db)
    date = _today()
    added = []
    for e in candidates:
        top = max(strong_of(e), key=lambda t: t["lift"])
        note = f"lift={top['lift']} با {top['root']} (اطلسِ رصدخانه)"
        _append_injection(e["root"], "رصدخانه (خودکار)", note, breath_no, date)
        added.append(dict(root=e["root"], note=note))

    print(json.dumps({"منشأ": "رصدخانه (خودکار)", "تعدادِ_تزریق‌شده": len(added),
                      "تزریق‌ها": added}, ensure_ascii=False, indent=1))


def cmd_injection_report(date=None):
    """گزارشِ روزانهٔ تزریق‌ها — دستورِ باغبان: «در پایانِ هر روز گزارشی از
    همهٔ تزریق‌های خودکار و دلیلِ هر کدام ارائه شود.»

    مشتقِ محضِ queue_injections.json + life.db برای یک تاریخِ معین (پیش‌فرض:
    امروز)؛ هم چاپ می‌شود هم در database/queue_injection_reports/ ذخیره —
    قطعی، بی‌تولیدِ معنا، فقط تجمیعِ داده‌های ازپیش‌ثبت‌شده."""
    date = date or _today()
    db = sqlite3.connect("database/life.db")
    lived = {r for (r,) in db.execute("SELECT pursued_root FROM breaths")}
    items = [i for i in load_injections() if i.get("date") == date]

    by_source = {}
    for i in items:
        by_source.setdefault(i["source"], []).append(i)

    report = {
        "تاریخ": date,
        "کلِ_تزریق‌های_امروز": len(items),
        "بر_حسبِ_منشأ": {src: len(v) for src, v in by_source.items()},
        "جزئیات": [{"root": i["root"], "source": i["source"], "note": i["note"],
                    "زیسته_شده": (i["root"] in lived)} for i in items],
    }
    os.makedirs("database/queue_injection_reports", exist_ok=True)
    with open(f"database/queue_injection_reports/{date}.json", "w", encoding="utf-8") as f:
        json.dump(report, f, ensure_ascii=False, indent=1)
        f.write("\n")
    print(json.dumps(report, ensure_ascii=False, indent=1))


def cmd_verify():
    db = sqlite3.connect("database/life.db")
    checks = verify_checks(db)
    ok = True
    for cmd, record in checks:
        # shlex نه cmd.split(): برخی نفس‌های L3 آرگومانِ چندکلمه‌ای دارند
        # (مثلِ chosen_by نقل‌قول‌شده) — split سادهٔ فاصله آن را می‌شکست.
        out = subprocess.run([sys.executable, *shlex.split(cmd)],
                             capture_output=True, text=True).stdout
        match = out == open(record).read()
        ok &= match
        print(("✓" if match else "✗"), cmd)
    print("REPRODUCIBLE" if ok else "MISMATCH — تحقیق لازم است")
    sys.exit(0 if ok else 1)


