    elif args[0] == "breathe":
        cmd_breathe(args[1] if len(args) > 1 else None)
    elif args[0] == "verify":
        cmd_verify()
    elif args[0] == "seed-db":
        cmd_seed_db()
    elif args[0] == "observe":
        cmd_observe(args[1] if len(args) > 1 else None)
    else:
        print(__doc__)
        sys.exit(1)
